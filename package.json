{
  "name": "crdt-migrate",
  "version": "1.0.0",
  "description": "CLI tool for migrating SQLite databases to CRDT-compatible schemas",
  "main": "dist/index.js",
  "bin": {
    "crdt-migrate": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "crdt",
    "sqlite",
    "migration",
    "database",
    "local-first",
    "offline-first",
    "sync"
  ],
  "author": "Sulthon Zh",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.0.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sqlite3": "^3.1.11",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/crdt-migrate"
  },
  "homepage": "https://github.com/sulthonzh/crdt-migrate#readme",
  "bugs": {
    "url": "https://github.com/sulthonzh/crdt-migrate/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
